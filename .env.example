# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kite Chain (server)
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
KITE_BUNDLER_URL=https://bundler-service.staging.gokite.ai/rpc/
KITE_PRICE_USD=0.01
DECISION_LOG_CONTRACT=0xYourDecisionLogContract
AGENT_MASTER_PRIVATE_KEY=0xYourPrivateKey
AGENT_SIGNER_ENCRYPTION_KEY=replace-with-random-secret
AGENT_AUTO_MIN_INTERVAL_SECONDS=90
AGENT_AUTO_MAX_AGENTS_PER_TICK=6
KITE_SWAP_ROUTER_ADDRESS=
KITE_BRIDGE_CONTROLLER_ADDRESS=
KITE_BRIDGE_ADAPTER_ADDRESS=
KITE_YIELD_VAULT_ADDRESS=
# Example (mainnet bridge): KITE_BRIDGE_CONTROLLER_ADDRESS=0x92E2391d0836e10b9e5EAB5d56BfC286Fadec25b
# Example (mainnet bridge): KITE_BRIDGE_ADAPTER_ADDRESS=0x5eF37628d45C80740fb6dB7eD9c0a753b4f85263

# Kite Chain (client/public)
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai
NEXT_PUBLIC_KITE_CHAIN_ID=2368
NEXT_PUBLIC_DECISION_LOG_CONTRACT=0xYourDecisionLogContract
NEXT_PUBLIC_AGENT_AUTO_POLL_MS=45000
NEXT_PUBLIC_DEFAULT_FAST_AUTOPILOT=true

# WalletConnect / RainbowKit
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# AI Provider
# Use "gemini" (recommended for free-tier testing) or "openai"
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (optional if AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=your-anthropic-key

# Optional external data providers
# COINGECKO_API_KEY=your-coingecko-key

# Demo mode (no Supabase auth required for judges/local demos)
DEMO_NO_AUTH=1
NEXT_PUBLIC_DEMO_NO_AUTH=1
